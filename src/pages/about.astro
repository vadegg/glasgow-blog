---
import BaseLayout from '../layouts/BaseLayout.astro';
import { ORGANIZATION, SITE } from '../data/site';

const structuredData = [
  ORGANIZATION,
  {
    '@context': 'https://schema.org',
    '@type': 'AboutPage',
    name: 'About Glasgow Research Blog',
    url: `${SITE.url}/about/`,
    description:
      'How Glasgow Research Blog is positioned, who it is for, what it covers, and how articles are reviewed before publication.'
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        name: 'Home',
        item: SITE.url
      },
      {
        '@type': 'ListItem',
        position: 2,
        name: 'About',
        item: `${SITE.url}/about/`
      }
    ]
  }
];
---

<BaseLayout
  title="About | Glasgow Research Blog"
  description="How Glasgow Research Blog is positioned, who it is for, what it covers, and how articles are reviewed before publication."
  structuredData={structuredData}
>
  <main class="shell" style="padding: 64px 0 96px;">
    <section class="card" style="padding: 48px; max-width: 860px; margin: 0 auto;">
      <p class="eyebrow">About</p>
      <h1 style="font-size: clamp(2.4rem, 6vw, 4.5rem); line-height: 1; margin: 12px 0 18px;">
        What this blog is actually about
      </h1>
      <div class="prose">
        <p>
          Glasgow Research Blog is where agency-backed personal expertise turns into public writing. It sits next to
          Glasgow Research, but it is written from Vadim Glazkov&apos;s field experience working with founders and B2B SaaS
          teams that need reliable market evidence before making product, growth, and go-to-market decisions.
        </p>
        <h2>What gets published here</h2>
        <p>
          The blog is focused on product research, customer interviews, JTBD, market validation, go-to-market research,
          growth research in B2B SaaS, and the systems founders use to make better decisions with real market input.
        </p>
        <h2>Who the blog is for</h2>
        <p>
          The primary audience is founders, product leaders, early-stage B2B SaaS teams, growth teams, and agencies
          working in IT markets across the US and Europe.
        </p>
        <h2>What the blog is not for</h2>
        <p>
          This is not a general management blog, not a lifestyle blog, and not a place for generic AI commentary. It is
          intentionally narrow. The point is to stay close to research, evidence, and decision quality.
        </p>
        <h2>Language and market rule</h2>
        <p>
          All articles in this project are written in English. The blog is aimed at US and EU readers, so topics,
          examples, and terminology should stay relevant to that market instead of drifting into generic global content.
        </p>
        <h2>How articles are reviewed</h2>
        <p>
          Articles are reviewed before publication for clarity, specificity, internal consistency, and whether they say
          something that would still be useful to a founder or operator making a real decision.
        </p>
        <h2>Editorial rule of thumb</h2>
        <p>
          If a piece feels generic, drifts away from research-first topics, overstates confidence, or sounds polished
          without carrying real signal, it is not ready to publish.
        </p>
      </div>
    </section>
  </main>
</BaseLayout>
