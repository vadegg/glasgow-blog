---
import BaseLayout from '../layouts/BaseLayout.astro';
import { ORGANIZATION, SITE } from '../data/site';

const structuredData = [
  ORGANIZATION,
  {
    '@context': 'https://schema.org',
    '@type': 'AboutPage',
    name: 'About Glasgow Research Blog',
    url: `${SITE.url}/about/`,
    description:
      'How Glasgow Research Blog is positioned, who it is for, what it covers, and how articles are reviewed before publication.'
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        name: 'Home',
        item: SITE.url
      },
      {
        '@type': 'ListItem',
        position: 2,
        name: 'About',
        item: `${SITE.url}/about/`
      }
    ]
  }
];
---

<BaseLayout
  title="About | Glasgow Research Blog"
  description="How Glasgow Research Blog is positioned, who it is for, what it covers, and how articles are reviewed before publication."
  structuredData={structuredData}
>
  <main class="shell page-wrap">
    <section class="card hero-card" style="max-width: 900px; margin: 0 auto;">
      <p class="hero-kicker">About</p>
      <h1 class="section-title" style="margin-bottom: 18px;">What this blog is actually about</h1>
      <div class="prose">
        <p>
          Glasgow Research Blog is where agency-backed personal expertise turns into public writing. It sits next to
          Glasgow Research, but it is written from Vadim Glazkov&apos;s field experience working with founders and B2B SaaS
          teams that need reliable market evidence before making product, growth, and go-to-market decisions.
        </p>
        <div class="section-stack" style="margin-top: 22px;">
          <section class="panel">
            <h2 class="eyebrow">What gets published here</h2>
            <p class="muted" style="margin: 14px 0 0; line-height: 1.75;">
              The blog is focused on product research, customer interviews, JTBD, market validation, go-to-market
              research, growth research in B2B SaaS, and the systems founders use to make better decisions with real
              market input.
            </p>
          </section>
          <section class="panel">
            <h2 class="eyebrow">Who the blog is for</h2>
            <p class="muted" style="margin: 14px 0 0; line-height: 1.75;">
              The primary audience is founders, product leaders, early-stage B2B SaaS teams, growth teams, and
              agencies working in IT markets across the US and Europe.
            </p>
          </section>
          <section class="panel">
            <h2 class="eyebrow">What the blog is not for</h2>
            <p class="muted" style="margin: 14px 0 0; line-height: 1.75;">
              This is not a general management blog, not a lifestyle blog, and not a place for generic AI commentary.
              It is intentionally narrow. The point is to stay close to research, evidence, and decision quality.
            </p>
          </section>
          <section class="panel">
            <h2 class="eyebrow">Language and market rule</h2>
            <p class="muted" style="margin: 14px 0 0; line-height: 1.75;">
              All articles in this project are written in English. The blog is aimed at US and EU readers, so topics,
              examples, and terminology should stay relevant to that market instead of drifting into generic global
              content.
            </p>
          </section>
          <section class="panel">
            <h2 class="eyebrow">How articles are reviewed</h2>
            <p class="muted" style="margin: 14px 0 0; line-height: 1.75;">
              Articles are reviewed before publication for clarity, specificity, internal consistency, and whether they
              say something that would still be useful to a founder or operator making a real decision.
            </p>
          </section>
          <section class="panel">
            <h2 class="eyebrow">Editorial rule of thumb</h2>
            <p class="muted" style="margin: 14px 0 0; line-height: 1.75;">
              If a piece feels generic, drifts away from research-first topics, overstates confidence, or sounds
              polished without carrying real signal, it is not ready to publish.
            </p>
          </section>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
