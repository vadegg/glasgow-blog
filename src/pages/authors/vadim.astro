---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { AUTHORS, ORGANIZATION, SITE } from '../../data/site';

const author = AUTHORS.vadim;
const posts = (await getCollection('blog'))
  .filter((post) => post.data.authorSlug === author.slug)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const personSchema = {
  '@type': 'Person',
  name: author.name,
  url: author.url,
  description: author.bio,
  jobTitle: author.role,
  worksFor: {
    '@type': 'Organization',
    name: SITE.organizationName,
    url: SITE.organizationUrl
  }
};

const structuredData = [
  ORGANIZATION,
  {
    '@context': 'https://schema.org',
    '@type': 'ProfilePage',
    name: `${author.name} | ${SITE.name}`,
    url: author.url,
    description: author.bio,
    mainEntity: personSchema
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        name: 'Home',
        item: SITE.url
      },
      {
        '@type': 'ListItem',
        position: 2,
        name: 'Author',
        item: author.url
      }
    ]
  }
];
---

<BaseLayout
  title={`${author.name} | ${author.role}`}
  description={author.bio}
  structuredData={structuredData}
>
  <main class="shell page-wrap">
    <section class="card hero-card" style="max-width: 900px; margin: 0 auto;">
      <div class="author-hero">
        <div>
          <p class="hero-kicker">Author</p>
          <h1 class="section-title">{author.name}</h1>
          <p class="lede muted">{author.bio}</p>
          <p class="muted" style="margin-top: 12px;">{author.role} · {author.expertTitle}</p>

          <div class="prose" style="margin-top: 28px;">
            <p>{author.summary}</p>
            <p>
              His work spans product research, JTBD studies, market validation, and decision support for SaaS, AI, and
              founder-led teams that need something more useful than guesswork.
            </p>
            <p>
              Public recommendations repeatedly point to clarity, structure, and practical research thinking rather than
              abstract theory.
            </p>
          </div>
        </div>

        <aside class="author-photo-panel" aria-label="Author photo">
          {author.photoPath ? (
            <img class="author-photo" src={author.photoPath} alt={author.photoAlt} />
          ) : (
            <div class="author-photo-placeholder">
              <span class="author-photo-placeholder-mark">VG</span>
              <p class="muted" style="margin: 10px 0 0;">Author photo</p>
            </div>
          )}
        </aside>
      </div>

      <div style="margin-top: 40px;">
        <h2 style="margin: 0 0 18px;">Published articles</h2>
        <div class="post-grid">
          {posts.map((post) => (
            <article class="panel">
              <p class="eyebrow">{post.data.category}</p>
              <h3 style="margin: 10px 0 8px;">
                <a href={`/blog/${post.data.slug}/`} style="text-decoration: none;">
                  {post.data.title}
                </a>
              </h3>
              <p class="muted" style="line-height: 1.7; margin: 0;">{post.data.description}</p>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
