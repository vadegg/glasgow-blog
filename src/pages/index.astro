---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Glasgow Blog"
  description="A focused blog for AI-assisted articles, SEO, and product research."
>
  <main class="shell" style="padding: 64px 0 96px;">
    <section class="card" style="padding: 48px;">
      <p class="eyebrow">Glasgow Works</p>
      <h1 style="font-size: clamp(3rem, 7vw, 5.6rem); line-height: 0.95; margin: 12px 0 20px;">
        Blog for strong SEO and useful AI-assisted content.
      </h1>
      <p class="muted" style="font-size: 1.1rem; max-width: 62ch; line-height: 1.7;">
        This site is a clean static blog scaffold for blog.glasgow.works.
      </p>
      <p style="margin-top: 28px;">
        <a href="/blog/" style="display:inline-block; padding: 14px 22px; border-radius: 999px; background: var(--text); color: white; text-decoration: none;">
          Read the first post
        </a>
      </p>
    </section>
  </main>
</BaseLayout>
