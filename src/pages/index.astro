---
import BaseLayout from '../layouts/BaseLayout.astro';
import { ORGANIZATION, SITE } from '../data/site';

const structuredData = [
  ORGANIZATION,
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: SITE.name,
    url: SITE.url,
    description: SITE.description,
    publisher: {
      '@type': 'Organization',
      name: SITE.organizationName,
      url: SITE.organizationUrl
    }
  }
];
---

<BaseLayout
  title="Glasgow Blog"
  description="A focused blog for product research, SEO, and modern editorial systems."
  structuredData={structuredData}
>
  <main class="shell" style="padding: 64px 0 96px;">
    <section class="card" style="padding: 48px;">
      <p class="eyebrow">Glasgow Works</p>
      <h1 style="font-size: clamp(3rem, 7vw, 5.6rem); line-height: 0.95; margin: 12px 0 20px;">
        Blog for strong SEO and useful, well-edited content.
      </h1>
      <p class="muted" style="font-size: 1.1rem; max-width: 62ch; line-height: 1.7;">
        This site is a clean static blog scaffold for blog.glasgow.works.
      </p>
      <div class="action-row" style="margin-top: 28px;">
        <a class="button-link" href="/blog/">
          Browse articles
        </a>
        <a class="text-link" href="/about/">
          See how the blog is made
        </a>
      </div>
    </section>
  </main>
</BaseLayout>
