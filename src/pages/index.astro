---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { ORGANIZATION, SITE } from '../data/site';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const latestPost = posts[0];
const structuredData = [
  ORGANIZATION,
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: SITE.name,
    url: SITE.url,
    description: SITE.description,
    publisher: {
      '@type': 'Organization',
      name: SITE.organizationName,
      url: SITE.organizationUrl
    }
  }
];
---

<BaseLayout
  title="Glasgow Research Blog"
  description={SITE.description}
  structuredData={structuredData}
>
  <main class="shell page-wrap">
    <section class="hero-grid">
      <div class="card hero-card">
        <p class="hero-kicker">{SITE.brandName}</p>
        <h1 class="hero-title">
          Product research notes for teams that need <span class="hero-script">signal</span>.
        </h1>
        <p class="hero-copy muted">
          Customer interviews, JTBD, validation, and the messy part between hearing the market and making a decision.
        </p>
        <div class="action-row" style="margin-top: 28px;">
          <a class="button-link" href="/blog/">Browse articles</a>
          <a class="button-link secondary" href="/about/">About this blog</a>
        </div>
      </div>

      <aside class="section-stack">
        <div class="panel">
          <p class="eyebrow">What this blog does</p>
          <p class="muted" style="margin-top: 16px; line-height: 1.75;">
            Research notes, interview patterns, and validation lessons turned into something another team can actually
            use.
          </p>
        </div>

        <div class="panel">
          <p class="eyebrow">Latest article</p>
          {latestPost ? (
            <div style="margin-top: 16px;">
              <h2 style="margin: 0 0 8px; font-size: 1.6rem; line-height: 1.08;">
                <a href={`/blog/${latestPost.data.slug}/`} style="text-decoration: none;">
                  {latestPost.data.title}
                </a>
              </h2>
              <p class="muted" style="margin: 0; line-height: 1.7;">{latestPost.data.description}</p>
            </div>
          ) : (
            <p class="muted" style="margin-top: 16px;">No articles yet.</p>
          )}
        </div>
      </aside>
    </section>

    <section class="section-grid section-grid--split" style="margin-top: 22px;">
      <article class="panel">
        <p class="eyebrow">Primary topics</p>
        <ul class="panel-list" style="margin-top: 16px;">
          {SITE.primaryTopics.map((topic) => (
            <li class="stat"><strong>{topic}</strong></li>
          ))}
        </ul>
      </article>

      <article class="panel">
        <p class="eyebrow">Why this is not theory</p>
        <p class="muted" style="margin-top: 16px; line-height: 1.75;">
          The writing here comes out of actual research work: interviews, JTBD studies, validation projects, and the
          kind of founder questions that show up when a decision is expensive and the signal is still messy.
        </p>
        <ul class="panel-list" style="margin-top: 16px;">
          {SITE.proofPoints.map((point) => (
            <li class="stat"><strong>{point}</strong></li>
          ))}
        </ul>
      </article>
    </section>
  </main>
</BaseLayout>
