---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { ORGANIZATION, SITE } from '../../data/site';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const structuredData = [
  ORGANIZATION,
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'Blog',
    url: `${SITE.url}/blog/`,
    description: 'Articles about product research, customer interviews, JTBD, market validation, and B2B SaaS growth research.'
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        name: 'Home',
        item: SITE.url
      },
      {
        '@type': 'ListItem',
        position: 2,
        name: 'Blog',
        item: `${SITE.url}/blog/`
      }
    ]
  }
];
---

<BaseLayout
  title="Blog | Glasgow Research"
  description="Articles about product research, customer interviews, JTBD, market validation, and B2B SaaS growth research."
  structuredData={structuredData}
>
  <main class="shell page-wrap">
    <section class="card hero-card">
      <p class="hero-kicker">Blog</p>
      <h1 class="hero-title">Latest posts.</h1>
      <p class="hero-copy muted">
        Articles about product research, customer interviews, JTBD, market validation, and B2B SaaS growth research.
      </p>
    </section>

    <section class="post-grid" style="margin-top: 22px;">
      {posts.map((post) => (
        <article class="card post-card">
          <p class="eyebrow">{post.data.category}</p>
          <h2>
            <a href={`/blog/${post.data.slug}/`} style="text-decoration: none;">
              {post.data.title}
            </a>
          </h2>
          <p class="muted" style="line-height: 1.75; max-width: 70ch;">{post.data.description}</p>
          <div class="post-meta">
            <span>By <a href={`/authors/${post.data.authorSlug}/`}>{post.data.author}</a></span>
            <span>{new Intl.DateTimeFormat('en', { dateStyle: 'long' }).format(post.data.pubDate)}</span>
          </div>
          <div class="tag-list">
            {post.data.tags.map((tag) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        </article>
      ))}
    </section>
  </main>
</BaseLayout>
