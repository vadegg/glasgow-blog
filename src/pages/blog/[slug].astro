---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import { getAuthor, ORGANIZATION, SITE } from '../../data/site';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.data.slug },
    props: { post }
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const author = getAuthor(post.data.authorSlug);
const postUrl = `${SITE.url}/blog/${post.data.slug}/`;
const publishedLabel = new Intl.DateTimeFormat('en', { dateStyle: 'long' }).format(post.data.pubDate);
const updatedLabel = post.data.updatedDate
  ? new Intl.DateTimeFormat('en', { dateStyle: 'long' }).format(post.data.updatedDate)
  : null;
const structuredData = [
  ORGANIZATION,
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        name: 'Home',
        item: SITE.url
      },
      {
        '@type': 'ListItem',
        position: 2,
        name: 'Blog',
        item: `${SITE.url}/blog/`
      },
      {
        '@type': 'ListItem',
        position: 3,
        name: post.data.title,
        item: postUrl
      }
    ]
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BlogPosting',
    headline: post.data.title,
    description: post.data.description,
    datePublished: post.data.pubDate.toISOString(),
    ...(post.data.updatedDate ? { dateModified: post.data.updatedDate.toISOString() } : {}),
    articleSection: post.data.category,
    keywords: post.data.tags.join(', '),
    mainEntityOfPage: postUrl,
    url: postUrl,
    author: {
      '@type': 'Person',
      name: author?.name ?? post.data.author,
      url: author?.url
    },
    publisher: {
      '@type': 'Organization',
      name: SITE.organizationName,
      url: SITE.organizationUrl,
      logo: {
        '@type': 'ImageObject',
        url: SITE.logoUrl
      }
    }
  }
];
---

<BaseLayout
  title={`${post.data.title} | Glasgow Blog`}
  description={post.data.description}
  type="article"
  structuredData={structuredData}
>
  <main class="shell" style="padding: 64px 0 96px;">
    <article class="card" style="padding: 48px; max-width: 860px; margin: 0 auto;">
      <p class="eyebrow">
        <a href="/blog/" style="text-decoration: none;">Blog</a> / {post.data.category}
      </p>
      <h1 style="font-size: clamp(2.5rem, 6vw, 4.8rem); line-height: 1; margin: 12px 0 18px;">
        {post.data.title}
      </h1>
      <div class="article-meta">
        <span>
          By <a href={`/authors/${post.data.authorSlug}/`}>{post.data.author}</a>
        </span>
        <span>{publishedLabel}</span>
        {updatedLabel && <span>Updated {updatedLabel}</span>}
      </div>
      <p class="muted" style="margin-bottom: 28px;">{post.data.description}</p>
      <div class="prose">
        <Content />
      </div>
      <section class="subcard">
        <p class="eyebrow">Author</p>
        <h2 style="margin: 12px 0 10px;">About {author?.name ?? post.data.author}</h2>
        <p class="muted" style="line-height: 1.7; max-width: 64ch;">
          {author?.bio ?? `${post.data.author} writes on Glasgow Blog.`}
        </p>
        <p style="margin: 18px 0 0;">
          <a class="text-link" href={`/authors/${post.data.authorSlug}/`}>View author page</a>
        </p>
      </section>
      <section class="subcard">
        <p class="eyebrow">Editorial process</p>
        <p class="muted" style="line-height: 1.7; max-width: 64ch; margin: 0;">
          This article was reviewed and edited before publication for clarity, structure, and accuracy.
          <a class="text-link" href="/about/" style="margin-left: 6px;">Read more about the workflow.</a>
        </p>
      </section>
    </article>
  </main>
</BaseLayout>
